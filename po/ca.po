#: src/background.c:931
#, c-format
msgid "Allow %s to Run in the Background?"
msgstr "Voleu que %s s'executi en segon pla?"

#: src/background.c:935
#, c-format
msgid "%s wants to be started automatically and run in the background"
msgstr "%s vol iniciar-se automàticament i executar-se en segon pla"

#: src/background.c:937
#, c-format
msgid "%s wants to run in the background"
msgstr "%s vol executar-se en segon pla"

#: src/background.c:938
msgid ""
"The ‘run in background’ permission can be changed at any time from the app "
"settings"
msgstr ""
"El permís «executa en segon pla» es pot canviar en qualsevol moment des dels "
"paràmetres de l'aplicació"

#: src/background.c:942
msgid "Don't allow"
msgstr "No ho permetis"

#: src/background.c:943 src/screenshot.c:222 src/wallpaper.c:191
msgid "Allow"
msgstr "Permet"

#: src/camera.c:104
#, c-format
msgid "Allow %s to Use the Camera?"
msgstr "Voleu permetre que %s utilitzi la càmera?"

#: src/camera.c:105
#, c-format
msgid "%s wants to access the camera"
msgstr "%s vol accedir a la càmera"

#: src/camera.c:109
msgid "Allow Apps to Use the Camera?"
msgstr "Voleu permetre que les aplicacions utilitzin la càmera?"

#: src/camera.c:110
msgid "An app wants to access the camera"
msgstr "Una aplicació vol accedir a la càmera"

#: src/camera.c:113 src/screenshot.c:274 src/wallpaper.c:207
msgid "This permission can be changed at any time from the privacy settings"
msgstr ""
"Aquest permís es pot canviar en qualsevol moment des de la configuració de "
"privacitat"

#: src/dynamic-launcher.c:128
#, c-format
msgid "Desktop file id missing .desktop suffix: %s"
msgstr "Manca l'ID del fitxer d'escriptori .desktop sufix: %s"

#: src/dynamic-launcher.c:139
#, c-format
msgid "Desktop file id is not valid"
msgstr "L'ID del fitxer d'escriptori no és vàlid"

#: src/dynamic-launcher.c:311
#, c-format
msgid "Desktop entry given to Install() not a valid key file"
msgstr ""
"L'entrada d'escriptori donada a Install() no és un fitxer de clau vàlid"

#: src/dynamic-launcher.c:324
#, c-format
msgid "Desktop entry given to Install() must have exactly one group"
msgstr ""
"L'entrada d'escriptori donada a Install() ha de tenir exactament un grup"

#: src/dynamic-launcher.c:362
#, c-format
msgid "Token given is invalid: %s"
msgstr "El testimoni indicat no és vàlid: %s"

#: src/dynamic-launcher.c:405
#, c-format
msgid "Desktop entry given to Install() not valid"
msgstr "L'entrada d'escriptori donada a Install() no és vàlida"

#: src/dynamic-launcher.c:414 src/dynamic-launcher.c:874
#: src/dynamic-launcher.c:923
#, c-format
msgid "Desktop file exceeds max size (%d): %s"
msgstr "El fitxer d'escriptori supera la mida màxima (%d): %s"

#: src/dynamic-launcher.c:598
#, c-format
msgid "URL given is invalid: %s"
msgstr "L'URL indicat no és vàlid: %s"

#: src/dynamic-launcher.c:620
#, c-format
msgid "Invalid launcher type: %x"
msgstr "Tipus de llançador no vàlid: %x"

#: src/dynamic-launcher.c:627
#, c-format
msgid "Unsupported launcher type: %x"
msgstr "Tipus de llançador no admès: %x"

#: src/dynamic-launcher.c:693 src/dynamic-launcher.c:768
msgid "Dynamic launcher icon failed validation"
msgstr "Ha fallat la validació llançador d'icones dinàmic"

#: src/dynamic-launcher.c:784
#, c-format
msgid "RequestInstallToken() not allowed for app id %s"
msgstr "RequestInstallToken() no està permès per a l'ID d'aplicació %s"

#: src/dynamic-launcher.c:963
#, c-format
msgid "Desktop file '%s' icon at unrecognized path"
msgstr "La icona del fitxer d'escriptori «%s» al camí no reconegut"

#: src/dynamic-launcher.c:986
#, c-format
msgid "Desktop file '%s' icon failed to serialize"
msgstr "La icona del fitxer d'escriptori «%s» no s'ha pogut serialitzar"

#: src/dynamic-launcher.c:1025
#, c-format
msgid "No dynamic launcher exists with id '%s'"
msgstr "No hi ha cap llançador dinàmic amb l'ID «%s»"

#: src/dynamic-launcher.c:1044
#, c-format
msgid "Failed to create GDesktopAppInfo for launcher with id '%s'"
msgstr ""
"No s'ha pogut crear el GDesktopAppInfo per al llançador amb l'identificador "
"«%s»"

#: src/location.c:552
msgid "Deny Access"
msgstr "Denega l'accés"

#: src/location.c:554
msgid "Grant Access"
msgstr "Permet l'accés"

#: src/location.c:560
#, c-format
msgid "Allow %s to Access Your Location?"
msgstr "Voleu permetre que %s tingui accés a la vostra ubicació?"

#: src/location.c:570
#, c-format
msgid "%s wants to use your location"
msgstr "%s vol saber la vostra ubicació"

#: src/location.c:576
msgid "Allow Apps to Access Your Location?"
msgstr "Voleu permetre les aplicacions tinguin accés a la vostra ubicació?"

#: src/location.c:577
msgid "An app wants to use your location"
msgstr "Una aplicació vol utilitzar la vostra ubicació"

#: src/location.c:580
msgid "Location access can be changed at any time from the privacy settings"
msgstr ""
"L'accés a la ubicació es pot canviar en qualsevol moment des de la "
"configuració de privacitat"

#: src/screenshot.c:220 src/wallpaper.c:189
msgid "Deny"
msgstr "Denega"

#: src/screenshot.c:246
#, c-format
msgid "Allow %s to Take Screenshots?"
msgstr "Voleu permetre que %s faci captures de pantalla?"

#: src/screenshot.c:247
#, c-format
msgid "%s wants to take screenshots at any time"
msgstr "%s vol fer captures de pantalla en qualsevol moment"

#: src/screenshot.c:251
#, c-format
msgid "Allow %s to Take a Screenshot?"
msgstr "Voleu permetre que %s faci una captura de pantalla?"

#: src/screenshot.c:252
#, c-format
msgid "%s wants to take a screenshot"
msgstr "%s vol fer una captura de pantalla"

#. Note: this will set the screenshot permission for all unsandboxed
#. * apps for which an app ID can't be determined.
#.
#: src/screenshot.c:263
msgid "Allow Apps to Take Screenshots?"
msgstr "Voleu permetre que les aplicacions facin captures de pantalla?"

#: src/screenshot.c:264
msgid "An app wants to take screenshots at any time"
msgstr "Una aplicació vol fer captures de pantalla en qualsevol moment"

#: src/screenshot.c:268
msgid "Allow to Take a Screenshot?"
msgstr "Voleu permetre fer una captura de pantalla?"

#: src/screenshot.c:269
msgid "An app wants to take a screenshot"
msgstr "Una aplicació vol fer una captura de pantalla"

#: src/settings.c:195 src/settings.c:234
msgid "Requested setting not found"
msgstr "No s'ha trobat la configuració sol·licitada"

#: src/usb.c:1341
msgid "Device not available"
msgstr "El dispositiu no està disponible"

#: src/usb.c:1355
msgid "Not allowed"
msgstr "No permès"

#: src/wallpaper.c:197
#, c-format
msgid "Allow %s to Set Backgrounds?"
msgstr "Voleu permetre que %s defineixi els fons?"

#: src/wallpaper.c:198
#, c-format
msgid "%s wants to change the background image"
msgstr "%s vol canviar la imatge de fons"

#: src/wallpaper.c:203
msgid "Allow Apps to Set Backgrounds?"
msgstr "Voleu permetre que les aplicacions estableixin els fons?"

#: src/wallpaper.c:204
msgid "An app wants to change the background image"
msgstr "Una aplicació vol canviar la imatge de fons"

